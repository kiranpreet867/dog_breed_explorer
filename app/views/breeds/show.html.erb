<div class="card">
  <div class="card-body">
    <h1 class="card-title"><%= @breed.name %></h1>

    <p class="text-muted">
      Total Reviews:
      <strong><%= @breed.reviews.count %></strong>
    </p>

    <hr>

    <h3>Reviews</h3>

    <% @breed.reviews.each do |review| %>
      <div class="card mb-3">
        <div class="card-body">
          <h5><%= review.reviewer_name %></h5>

          <p>
            <strong>Rating:</strong>
            <%= review.rating %>/5
          </p>

          <p><%= review.comment %></p>
        </div>
      </div>
    <% end %>

    <%= link_to "← Back to Dog Breeds", breeds_path, class: "btn btn-primary" %>
  </div>
</div>