<% content_for :title, @breed.name %>

<div class="card shadow">
  <div class="card-body">

    <h1 class="card-title"><%= @breed.name %></h1>

    <% if @breed.breed_images.any? %>
      <%= image_tag @breed.breed_images.first.image_url,
          class: "img-fluid rounded mb-3",
          style: "max-width: 400px;" %>
    <% end %>

    <span class="badge bg-primary mb-3">
      Reviews Available: <%= @breed.reviews.count %>
    </span>

    <hr>

    <h3>Reviews</h3>

    <% @breed.reviews.each do |review| %>
      <div class="card mb-3">
        <div class="card-body">
          <h5><%= review.reviewer_name %></h5>

          <p>
            <strong>Rating:</strong>
            <%= review.rating %>/5
          </p>

          <p><%= review.comment %></p>
        </div>
      </div>
    <% end %>

    <%= link_to "← Back to Dog Breeds", breeds_path, class: "btn btn-primary" %>

  </div>
</div>