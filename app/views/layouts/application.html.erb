<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Dog Breed Explorer" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark mb-4">
      <div class="container">
        <%= link_to "Dog Breed Explorer", root_path, class: "navbar-brand" %>
        <div>
          <%= link_to "Home", root_path, class: "btn btn-outline-light me-2" %>
          <%= link_to "About", about_path, class: "btn btn-outline-light" %>
        </div>
      </div>
    </nav>

    <main class="container">
      <%= yield %>
    </main>
  </body>
</html>
